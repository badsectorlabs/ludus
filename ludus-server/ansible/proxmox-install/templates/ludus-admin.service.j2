[Unit]
Description=Ludus admin server
Wants=network-online.target
After=network-online.target nss-lookup.target wg-quick@wg0.service

[Service]
Type=simple
User=root
ExecStart={{ ludus_install_path }}/ludus-server
Restart=always
RestartSec=5
RestartMaxDelaySec=1h
RestartSteps=10

[Install]
WantedBy=multi-user.target
